<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/btn_visit"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/visit_nus"
        android:textColor="@android:color/black"
        android:backgroundTint="#A0C4FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_call"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_locate" />

    <Button
        android:id="@+id/btn_locate"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/locate_nus"
        android:textColor="@android:color/black"
        android:backgroundTint="#FFD6A5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_email"
        app:layout_constraintStart_toEndOf="@id/btn_visit"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_call"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/call_nus"
        android:textColor="@android:color/black"
        android:backgroundTint="#C1E1C1"
        app:layout_constraintTop_toBottomOf="@id/btn_visit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_email" />

    <Button
        android:id="@+id/btn_email"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/email_nus"
        android:textColor="@android:color/black"
        android:backgroundTint="#D6C7E8"
        app:layout_constraintTop_toBottomOf="@id/btn_locate"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_call"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>